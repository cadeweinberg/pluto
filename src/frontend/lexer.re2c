#include "frontend/lexer.hpp"

namespace pluto {
Lexer::Lexer() 
    : m_location()
    , YYTOKEN(nullptr)
    , YYCURSOR(nullptr)
    , YYMARKER(nullptr)
    , YYLIMIT(nullptr) 
{}

Lexer::Lexer(std::string_view source) 
    : Lexer() 
{
    set(source);
}

void Lexer::set(std::string_view source) {
    m_location = {};
    YYTOKEN    = reinterpret_cast<unsigned char const *>(source.data());
    YYCURSOR   = YYTOKEN;
    YYMARKER   = YYTOKEN;
    YYLIMIT    = YYTOKEN + source.size();
}

void Lexer::reset() {
    m_location = {};
    YYTOKEN    = nullptr;
    YYCURSOR   = nullptr;
    YYMARKER   = nullptr;
    YYLIMIT    = nullptr;
}

std::string_view Lexer::current() const {
    if (YYTOKEN == nullptr) {
        return {};
    }
    return std::string_view(reinterpret_cast<char const *>(YYTOKEN), YYCURSOR - YYTOKEN);
}

SourceLocation Lexer::location() const {
    return m_location;
}

void Lexer::step() {
    YYTOKEN = YYCURSOR;
    m_location.first_line = m_location.last_line;
    m_location.first_column = m_location.last_column;
}

void Lexer::up() {
    if (YYCURSOR == YYLIMIT) {
        return;
    }

    unsigned char const *cursor = YYTOKEN;
    while (cursor < YYCURSOR) {
        switch (*cursor) {
        case '\n':
            m_location.first_line++;
            m_location.first_column = 1;
            break;
        default:
            m_location.first_column++;
            break;
        }
        cursor++;
    }
}


/*!re2c
  re2c:yyfill:enable = 0;
  re2c:eof = 0;

  re2c:define:YYCTYPE      = "unsigned char";
*/

/*!include:re2c "unicode_categories.re"*/

/*!re2c

  integer = [0-9][0-9]*;

  fractional = [0-9]* "." [0-9]+ | [0-9]+ ".";
  exponent   = 'e' [+-]? [0-9]+;
  float      = fractional exponent? | [0-9]+ exponent;

  // Simplified "Unicode Identifier and Pattern Syntax"
  // see https://unicode.org/reports/tr31
  id_start     = L | Nl | [_];
  id_continue  = id_start | Mn | Mc | Nd | Pc | [\u200D\u05F3];
  identifier   = id_start id_continue*;

  string = '"' ([^"\\] | '\\' .)* '"';

  end = "\x00";

  ws = [ \t\v\n\r]*;
 */

Token Lexer::next() {
    while (true) {
        step();
        /*!re2c
            $  { up(); return Token::EndOfFile; }
            ws { up(); continue; }

            "module" { up(); return Token::Module; }
            "type"   { up(); return Token::Type; }
            "let"    { up(); return Token::Let; }
            "fn"     { up(); return Token::Fn; }
            "struct" { up(); return Token::Struct; }

            "(" { up(); return Token::ParenBegin; }
            ")" { up(); return Token::ParenEnd; }
            "{" { up(); return Token::BraceBegin; }
            "}" { up(); return Token::BraceEnd; }
            "=" { up(); return Token::Equal; }
            ":" { up(); return Token::Colon; }
            ";" { up(); return Token::Semicolon; }
            "," { up(); return Token::Comma; }
            "->" { up(); return Token::Arrow; }
            "@" { up(); return Token::At; }

            "i8"   { up(); return Token::TypeI8; }
            "i16"  { up(); return Token::TypeI16; }
            "i32"  { up(); return Token::TypeI32; }
            "i64"  { up(); return Token::TypeI64; }
            "u8"   { up(); return Token::TypeU8; }
            "u16"  { up(); return Token::TypeU16; }
            "u32"  { up(); return Token::TypeU32; }
            "u64"  { up(); return Token::TypeU64; }
            "f32"  { up(); return Token::TypeF32; }
            "f64"  { up(); return Token::TypeF64; }
            "bool" { up(); return Token::TypeBool; }
            "nil"  { up(); return Token::TypeNil; }

            "true"     { up(); return Token::LiteralTrue; }
            "false"    { up(); return Token::LiteralFalse; }
            integer    { up(); return Token::LiteralInteger; }
            float      { up(); return Token::LiteralFloat; }
            string     { up(); return Token::LiteralString; }
            identifier { up(); return Token::Identifier; }

        */
    }
}

}
